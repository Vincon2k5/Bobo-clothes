# ==============================
# BoBo Backend - Environment Variables
# Copy file này thành .env và điền giá trị thực
# ==============================

# Server
NODE_ENV=production
PORT=5000

# MongoDB - Atlas URL
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bobo_fashion

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Client URL (CORS) - Vercel frontend URL
CLIENT_URL=https://your-vercel-domain.vercel.app

# ==============================
# Shipping API Placeholder (Giao Hàng Nhanh)
# ==============================
GHN_API_URL=https://online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=your_ghn_token_here
GHN_SHOP_ID=your_ghn_shop_id_here

# ==============================
# Payment API Placeholders
# ==============================
# MoMo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_API_URL=https://payment.momo.vn/v2/gateway/api

# ZaloPay
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_API_URL=https://sb-openapi.zalopay.vn/v2

# VietQR
VIETQR_BANK_ID=your_bank_id
VIETQR_ACCOUNT_NO=your_account_number
VIETQR_ACCOUNT_NAME=CONG TY BOBO FASHION
